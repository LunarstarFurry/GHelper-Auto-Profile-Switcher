<Window x:Class="GHelperAutoProfileSwitcher.ProcessSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Process" Height="300" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        
        <ListBox Name="ProcessListBox" Grid.Row="0" Margin="0,0,0,10" />
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="60" Margin="0,0,10,0" Click="Ok_Click" />
            <Button Content="Cancel" Width="60" Click="Cancel_Click" />
        </StackPanel>
    </Grid>
</Window>